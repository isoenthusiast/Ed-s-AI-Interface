# =============================================================================
# 🔒 SECRETS TEMPLATE — Copy to .secrets and fill in your keys
# =============================================================================
# This file shows all available configuration options.
# 1. Copy this file to .secrets
# 2. Fill in your actual API keys
# 3. .secrets is already gitignored — your keys stay safe

# === DeepSeek API (required) ===
# Get your API key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat

# === Optional: Other AI Providers ===
# OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# === Optional: Local LLM (ollama) ===
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=llama3

# === GitHub (for pushing to your remote repository) ===
# Get your token from: https://github.com/settings/tokens (scope: repo)
# GITHUB_TOKEN=ghp_your-personal-access-token

# === Agent Configuration ===
AGENT_NAME=Ed's AI Assistant
AGENT_TEMPERATURE=0.7
AGENT_MAX_TOKENS=4096
AGENT_SYSTEM_PROMPT=You are a helpful AI assistant for Ed. You are knowledgeable, friendly, and context-aware. Use the conversation history and stored memories to provide personalized, relevant responses.
